<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="128dp"
    android:height="128dp"
    android:viewportWidth="128"
    android:viewportHeight="128">

    <!-- Premium Glow effect or background tray -->
    <path
        android:pathData="M 44,116 L 84,116 M 44,106 L 44,116 M 84,106 L 84,116"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="44"
                android:startY="116"
                android:endX="84"
                android:endY="116"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF00E5FF" />
                <item android:offset="1.0" android:color="#FF2979FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Infinity Loop Path with Gradient -->
    <path
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 64,56 C 50,32 18,32 18,56 C 18,80 50,80 64,56 C 78,32 110,32 110,56 C 110,72 98,82 84,82 L 84,94">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="18"
                android:startY="56"
                android:endX="110"
                android:endY="56"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF00B0FF" />
                <item android:offset="0.5" android:color="#FF00E5FF" />
                <item android:offset="1.0" android:color="#FF2979FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Download Arrow Head pointing down -->
    <path
        android:fillType="nonZero"
        android:pathData="M 72,90 L 84,102 L 96,90 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="72"
                android:startY="94"
                android:endX="96"
                android:endY="94"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF00E5FF" />
                <item android:offset="1.0" android:color="#FF2979FF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
